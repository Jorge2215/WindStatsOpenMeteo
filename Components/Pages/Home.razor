@page "/"
@using WindStatsOpenMeteo.Models
@using WindStatsOpenMeteo.Services
@inject OpenMeteoService WindService
@inject GeocodingService GeoService
@inject IJSRuntime JS

<PageTitle>WindStats – OpenMeteo</PageTitle>

<div class="container-fluid py-3 px-4">

    <!-- ── Header ────────────────────────────────────────────── -->
    <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
        <div>
            <h1 class="h3 fw-bold text-primary mb-0">
                &#127744; WindStats <span class="text-muted fw-normal fs-6">powered by Open-Meteo</span>
            </h1>
        </div>
        <button class="btn btn-outline-primary btn-sm" @onclick="RefreshData" disabled="@_loading">
            @if (_loading)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                <span>Loading…</span>
            }
            else
            {
                <span>&#8635; Refresh</span>
            }
        </button>
    </div>

    <!-- ── Geolocation error / city search ───────────────────── -->
    @if (_geoError is not null)
    {
        <div class="alert alert-warning py-2 mb-3">
            <strong>&#9888; @_geoError</strong>
            <div class="mt-2 d-flex gap-2 flex-wrap">
                <input type="text" class="form-control form-control-sm" style="max-width:280px"
                       @bind="_searchQuery" @bind:event="oninput"
                       @onkeydown="OnSearchKeyDown"
                       placeholder="Search city (e.g. Madrid)…" />
                <button class="btn btn-primary btn-sm" @onclick="SearchCity" disabled="@_loading">
                    &#128269; Search
                </button>
            </div>
            @if (_searchResults.Count > 0)
            {
                <ul class="list-group mt-2" style="max-width:360px">
                    @foreach (var r in _searchResults)
                    {
                        <li class="list-group-item list-group-item-action py-1 px-3"
                            style="cursor:pointer" @onclick="() => SelectLocation(r)">
                            <strong>@r.Name</strong>
                            @if (!string.IsNullOrEmpty(r.Admin1)) { <span class="text-muted">, @r.Admin1</span> }
                            <span class="text-muted">, @r.Country</span>
                        </li>
                    }
                </ul>
            }
        </div>
    }

    <!-- ── Loading splash ────────────────────────────────────── -->
    @if (_loading && _location is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" style="width:3rem;height:3rem;" role="status"></div>
            <p class="mt-3 text-muted">Detecting your location and fetching wind data…</p>
        </div>
    }

    <!-- ── Main content (shown when data is ready) ───────────── -->
    @if (_location is not null)
    {
        <!-- Location badges -->
        <div class="mb-3 d-flex flex-wrap gap-2 align-items-center">
            <span class="badge bg-secondary fs-6">
                &#128205;
                @(string.IsNullOrEmpty(_location.City)
                    ? _location.DisplayName
                    : (_location.City + (!string.IsNullOrEmpty(_location.Country) ? ", " + _location.Country : "")))
            </span>
            <span class="badge bg-light text-dark border">
                @_location.Latitude.ToString("F4")°N &nbsp; @_location.Longitude.ToString("F4")°E
            </span>
            <span class="badge bg-info text-dark">40 km coverage radius</span>
            @if (_wind?.Current is not null)
            {
                <span class="badge bg-light text-muted border">
                    Updated: @_wind.Current.Time.ToString("HH:mm")
                </span>
            }
        </div>

        @if (_wind?.Current is { } cur)
        {
            <!-- ── KPI Cards ──────────────────────────────────── -->
            <div class="row g-3 mb-3">

                <!-- Wind Speed -->
                <div class="col-6 col-sm-3">
                    <div class="card wind-card h-100 border-primary">
                        <div class="card-body text-center p-3">
                            <div class="text-muted small text-uppercase fw-semibold">Wind Speed</div>
                            <div class="display-5 fw-bold text-primary lh-1 my-1">
                                @cur.Speed.ToString("F1")
                            </div>
                            <div class="text-muted small">km/h</div>
                        </div>
                    </div>
                </div>

                <!-- Direction -->
                <div class="col-6 col-sm-3">
                    <div class="card wind-card h-100 border-success">
                        <div class="card-body text-center p-3">
                            <div class="text-muted small text-uppercase fw-semibold">Direction</div>
                            <div class="compass-arrow-container">
                                <span class="compass-arrow text-success"
                                      style="transform:rotate(@(cur.Direction.ToString("F0", System.Globalization.CultureInfo.InvariantCulture))deg)">
                                    &#8679;
                                </span>
                            </div>
                            <div class="fw-bold fs-5 text-success">@cur.DirectionLabel</div>
                            <div class="text-muted small">@cur.Direction.ToString("F0")°</div>
                        </div>
                    </div>
                </div>

                <!-- Gusts -->
                <div class="col-6 col-sm-3">
                    <div class="card wind-card h-100 border-warning">
                        <div class="card-body text-center p-3">
                            <div class="text-muted small text-uppercase fw-semibold">Gusts</div>
                            <div class="display-5 fw-bold text-warning lh-1 my-1">
                                @cur.Gusts.ToString("F1")
                            </div>
                            <div class="text-muted small">km/h</div>
                        </div>
                    </div>
                </div>

                <!-- Beaufort -->
                <div class="col-6 col-sm-3">
                    <div class="card wind-card h-100 border-info">
                        <div class="card-body text-center p-3">
                            <div class="text-muted small text-uppercase fw-semibold">Beaufort</div>
                            <div class="display-5 fw-bold text-info lh-1 my-1">
                                @cur.BeaufortScale
                            </div>
                            <div class="text-info small fw-semibold">@cur.BeaufortDescription</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Daily Summary ─────────────────────────────── -->
            <div class="row g-3 mb-3">
                <div class="col-4">
                    <div class="card border-0 bg-light">
                        <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small">Max Speed Today</div>
                                <div class="fw-bold">@_wind.MaxSpeed.ToString("F1") km/h</div>
                            </div>
                            <span class="text-danger fs-4 fw-bold">&#8679;</span>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card border-0 bg-light">
                        <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small">Avg Speed Today</div>
                                <div class="fw-bold">@_wind.AvgSpeed.ToString("F1") km/h</div>
                            </div>
                            <span class="text-primary fs-4">&#126;</span>
                        </div>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card border-0 bg-light">
                        <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
                            <div>
                                <div class="text-muted small">Max Gusts Today</div>
                                <div class="fw-bold">@_wind.MaxGusts.ToString("F1") km/h</div>
                            </div>
                            <span class="fs-4">&#128168;</span>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- ── Map + Hourly ──────────────────────────────────── -->
        <div class="row g-3 mb-3">

            <!-- Map -->
            <div class="col-lg-7">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white border-bottom d-flex align-items-center gap-2">
                        <strong>&#127757; Coverage Map</strong>
                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                            40 km radius – OpenStreetMap
                        </span>
                    </div>
                    <div class="card-body p-0">
                        <div id="wind-map"></div>
                    </div>
                </div>
            </div>

            <!-- Hourly forecast -->
            <div class="col-lg-5">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-white border-bottom">
                        <strong>&#128336; Hourly Forecast</strong>
                        <span class="text-muted small ms-2">today (24 h)</span>
                    </div>
                    <div class="card-body p-0 hourly-scroll">
                        <table class="table table-sm table-hover table-striped mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Time</th>
                                    <th>Speed (km/h)</th>
                                    <th>Dir</th>
                                    <th>Gusts (km/h)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var h in _wind?.HourlyReadings ?? [])
                                {
                                    bool isCurrent = h.Time.Hour == DateTime.Now.Hour
                                                  && h.Time.Date == DateTime.Today;
                                    <tr class="@(isCurrent ? "table-primary fw-bold" : "")">
                                        <td>@h.Time.ToString("HH:mm")</td>
                                        <td>@h.Speed.ToString("F1")</td>
                                        <td title="@h.Direction.ToString("F0")°">@h.DirectionLabel</td>
                                        <td>@h.Gusts.ToString("F1")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

        </div>

        <!-- ── Footer credits ───────────────────────────────── -->
        <p class="text-muted small mb-0">
            Wind data: <a href="https://open-meteo.com" target="_blank" rel="noopener">Open-Meteo</a> &bull;
            Map tiles: <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener">OpenStreetMap</a> contributors &bull;
            Geocoding: <a href="https://nominatim.openstreetmap.org" target="_blank" rel="noopener">Nominatim</a> /
            <a href="https://open-meteo.com/en/docs/geocoding-api" target="_blank" rel="noopener">Open-Meteo Geocoding</a>
        </p>
    }

</div>

@code {
    private LocationInfo? _location;
    private WindResult? _wind;
    private bool _loading;
    private string? _geoError;
    private string _searchQuery = string.Empty;
    private List<GeocodingSearchResult> _searchResults = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await LoadFromGeolocation();
    }

    private async Task LoadFromGeolocation()
    {
        _loading = true;
        _geoError = null;
        StateHasChanged();

        try
        {
            var geo = await JS.InvokeAsync<GeolocationResult>("getGeolocation");
            await LoadDataForCoordinates(geo.Latitude, geo.Longitude, fromGeo: true);
        }
        catch (Exception ex)
        {
            _geoError = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadDataForCoordinates(double lat, double lon, bool fromGeo = false)
    {
        if (fromGeo)
            _location = await GeoService.ReverseGeocodeAsync(lat, lon);

        _wind = await WindService.GetWindDataAsync(lat, lon);

        await InvokeAsync(StateHasChanged);
        await Task.Delay(150); // let the DOM render the map div

        double dir = _wind?.Current?.Direction ?? 0;
        double spd = _wind?.Current?.Speed ?? 0;
        await JS.InvokeVoidAsync("windMapInterop.initMap", "wind-map", lat, lon, 40, dir, spd);
    }

    private async Task RefreshData()
    {
        if (_location is null) { await LoadFromGeolocation(); return; }

        _loading = true;
        StateHasChanged();
        try
        {
            _wind = await WindService.GetWindDataAsync(_location.Latitude, _location.Longitude);
            double dir = _wind?.Current?.Direction ?? 0;
            double spd = _wind?.Current?.Speed ?? 0;
            await JS.InvokeVoidAsync("windMapInterop.updateWindArrow",
                _location.Latitude, _location.Longitude, dir, spd);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task SearchCity()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery)) return;
        _loading = true;
        StateHasChanged();
        _searchResults = await GeoService.SearchLocationAsync(_searchQuery);
        _loading = false;
        StateHasChanged();
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SearchCity();
    }

    private async Task SelectLocation(GeocodingSearchResult result)
    {
        _searchResults = [];
        _geoError = null;
        _loading = true;
        _location = new LocationInfo
        {
            Latitude = result.Latitude,
            Longitude = result.Longitude,
            City = result.Name,
            Country = result.Country,
            DisplayName = string.Join(", ",
                new[] { result.Name, result.Admin1, result.Country }
                    .Where(s => !string.IsNullOrEmpty(s)))
        };
        StateHasChanged();

        try
        {
            await LoadDataForCoordinates(result.Latitude, result.Longitude, fromGeo: false);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }
}

